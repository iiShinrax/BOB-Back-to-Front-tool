# ==========================================
# BOB AI FULL-STACK GENERATOR
# Environment Configuration
# ==========================================

# OpenRouter API Key (Required)
# Get your key from: https://openrouter.ai/keys
# This is used to access AI models for code generation
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# Optional: Specify a different AI model
# Default: nvidia/nemotron-3-nano-30b-a3b:free
# MODEL_NAME=nvidia/nemotron-3-nano-30b-a3b:free

# Optional: Custom API endpoint
# Default: https://openrouter.ai/api/v1
# BASE_URL=https://openrouter.ai/api/v1

# ==========================================
# SETUP INSTRUCTIONS
# ==========================================
# 1. Copy this file to .env (without .example)
# 2. Replace 'your-api-key-here' with your actual OpenRouter API key
# 3. Save the file
# 4. Run: node ai-prompt-engineer.js
#
# Example:
# cp .env.example .env
# (Then edit .env with your actual key)
# ==========================================