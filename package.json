{
  "name": "bob-backend-generator",
  "displayName": "BOB Backend Generator",
  "description": "Automatically generates a complete Node.js + Express + MongoDB backend for your frontend application using AI",
  "version": "1.0.0",
  "publisher": "knd249-team",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mohamedahmed-Abdelgadir/BOB-Back-to-Front-tool.git"
  },
  "bugs": {
    "url": "https://github.com/Mohamedahmed-Abdelgadir/BOB-Back-to-Front-tool/issues"
  },
  "homepage": "https://github.com/Mohamedahmed-Abdelgadir/BOB-Back-to-Front-tool#readme",
  "license": "MIT",
  "keywords": [
    "backend",
    "generator",
    "ai",
    "express",
    "mongodb",
    "typescript",
    "react",
    "api",
    "fullstack",
    "automation"
  ],
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "bob.generateBackend",
        "title": "BOB: Generate Backend from Current Workspace"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "@types/vscode": "^1.75.0",
    "@typescript-eslint/eslint-plugin": "^5.x",
    "@typescript-eslint/parser": "^5.x",
    "eslint": "^8.x",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "dotenv": "^16.0.3",
    "openai": "^4.20.0"
  }
}
